# --- Public (browser / Next.js) ---
# Sanity (required for content)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
NEXT_PUBLIC_SANITY_API_VERSION=

# Site URL for metadata, sitemap, robots, payment redirects (full URL, e.g. https://luximport.org)
NEXT_PUBLIC_DOMAIN=

# Must match WAYFORPAY_MERCHANT_ACCOUNT (used by WayForPay iframe widget on profile)
NEXT_PUBLIC_WAYFORPAY_MERCHANT_ACCOUNT=

# Optional: Google Tag Manager container ID
NEXT_PUBLIC_GTM_ID=

# --- Server-only secrets ---
# Sanity write token (orders, webhooks, scripts)
SANITY_API_TOKEN=

# WayForPay
WAYFORPAY_MERCHANT_ACCOUNT=
WAYFORPAY_SECRET_KEY=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
ADMIN_EMAIL=

# Nova Poshta API
NOVA_POSHTA_API_KEY=
